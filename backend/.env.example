# Copy this file to .env and fill in real values. .env is gitignored.

# Public base URL the app is reachable at (used in email links).
# Local dev: http://localhost:8000
# Tunnel:    https://<subdomain>.trycloudflare.com
PQSHARE_BASE_URL=http://localhost:8000

# SMTP for sending confirmation + notification emails.
# For Gmail: use an App Password (not your regular password).
# Generate one at https://myaccount.google.com/apppasswords (2FA must be on).
PQSHARE_SMTP_HOST=smtp.gmail.com
PQSHARE_SMTP_PORT=587
PQSHARE_SMTP_USE_STARTTLS=true
PQSHARE_SMTP_USER=you@example.com
PQSHARE_SMTP_PASSWORD=your-app-password-no-spaces
PQSHARE_SMTP_FROM=you@example.com
PQSHARE_SMTP_FROM_NAME=pq-share
